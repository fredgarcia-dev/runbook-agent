    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }, "id": 10, "title": "Pipeline Performance", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 8, "gradientMode": "none", "spanNulls": false, "showPoints": "auto", "drawStyle": "line" },
          "color": { "mode": "palette-classic" }
