        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 11,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.5, sum by (le, severity) (rate(runbook_incident_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "P50 {{severity}}", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.9, sum by (le, severity) (rate(runbook_incident_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "P90 {{severity}}", "refId": "B" },
